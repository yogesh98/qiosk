// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("creator")
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kioskConfigurations KioskConfiguration[]
  kioskConfigurationLogs KioskConfigurationLog[]
  kioskConfigurationVersions KioskConfigurationVersion[]
}

model KioskConfiguration {
  id               String   @id @default(cuid())
  name             String
  width            Int      // immutable after creation
  height           Int      // immutable after creation
  currentVersionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  currentVersion KioskConfigurationVersion? @relation("KioskConfigurationCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  logs KioskConfigurationLog[]
  versions KioskConfigurationVersion[] @relation("KioskConfigurationVersions")
}

model KioskConfigurationVersion {
  id                   String   @id @default(cuid())
  version              Int
  content              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  kioskConfigurationId String
  createdById          String

  kioskConfiguration KioskConfiguration @relation("KioskConfigurationVersions", fields: [kioskConfigurationId], references: [id], onDelete: Cascade)
  createdBy          User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  currentForConfigurations KioskConfiguration[] @relation("KioskConfigurationCurrentVersion")

  @@unique([kioskConfigurationId, version])
  @@index([kioskConfigurationId, createdAt])
}

model KioskConfigurationLog {
  id                   String   @id @default(cuid())
  message              String
  createdAt            DateTime @default(now())
  kioskConfigurationId String
  createdById          String

  kioskConfiguration KioskConfiguration @relation(fields: [kioskConfigurationId], references: [id], onDelete: Cascade)
  createdBy          User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([kioskConfigurationId, createdAt])
}
